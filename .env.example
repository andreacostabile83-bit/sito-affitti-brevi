# Configurazione invio email per il form "Richiedi la tua analisi gratuita"
# (/valutazione-gratuita, API route app/api/leads/route.ts)
#
# Il progetto usa gia' Brevo (Sendinblue) per i form della newsletter/ebook,
# quindi il lead viene inviato via email con la stessa piattaforma, tramite
# la sua API transazionale (https://api.brevo.com/v3/smtp/email).

# Obbligatoria: API key di Brevo (Account > SMTP & API > API Keys).
BREVO_API_KEY=

# Facoltative (hanno un valore di default nel codice):
# Indirizzo che riceve la notifica di ogni nuovo lead.
LEAD_NOTIFICATION_EMAIL=info@acdomusaffitti.it

# Mittente tecnico dell'email: deve essere un dominio/mittente verificato
# nell'account Brevo (Impostazioni > Mittenti e IP), altrimenti Brevo
# rifiuta l'invio.
LEAD_FROM_EMAIL=no-reply@acdomusaffitti.it
LEAD_FROM_NAME=Sito AC Domus Affitti
